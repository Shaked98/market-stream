# market-stream runtime configuration. Copy to .env for local runs:
#   cp .env.example .env
# .env is gitignored — never commit real values. The local docker-compose stack reads
# these; on the cluster the same vars come from K8s ConfigMaps/Secrets (see ansible/).
#
# NOTE: nothing secret belongs in this file for the local stack — the local MinIO /
# Lakekeeper run with throwaway dev credentials. Real cloud secrets live in
# ansible/secrets/secrets.sops.yaml (SOPS-encrypted), never here.

# ── Producer: source feed ────────────────────────────────────────────────────
# Binance public combined-stream WebSocket (no API key for public market data).
WS_URL=wss://stream.binance.com:9443/stream
# Comma-separated symbols to subscribe to (Binance uses e.g. BTCUSDT, not BTC-USD).
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
SOURCE=binance

# ── Producer: Kafka / Redpanda ───────────────────────────────────────────────
KAFKA_BOOTSTRAP=redpanda:9092
SCHEMA_REGISTRY_URL=http://redpanda:8081
TOPIC_TRADES=market.trades
# Producer tuning (production defaults: durable + idempotent).
PRODUCER_ACKS=all
PRODUCER_LINGER_MS=50
PRODUCER_COMPRESSION=zstd
RECONNECT_MAX_BACKOFF_SECONDS=30

# ── Streaming: Spark Structured Streaming → Iceberg ──────────────────────────
ICEBERG_CATALOG=lake
ICEBERG_WAREHOUSE=lakehouse
TRADES_TABLE=lake.market.trades_raw
OHLCV_TABLE=lake.market.ohlcv_1m
WINDOW_DURATION=1 minute
WATERMARK_DELAY=2 minutes
CHECKPOINT_LOCATION=s3a://lakehouse/checkpoints/market-stream
# Local Lakekeeper has no OAuth2 (matches LakeHouse/local). On the cluster this is true
# and the OAuth2 client-credential is injected from the oidc-spark Secret.
OAUTH_ENABLED=false
ICEBERG_REST_URI=http://lakekeeper:8181/catalog
# S3 (local MinIO defaults — dev only, NOT secret).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_PATH_STYLE_ACCESS=true

# ── Web demo: read-only API ──────────────────────────────────────────────────
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=market-stream-web
TRINO_CATALOG=iceberg
# CORS: the exact origin the static frontend is served from. Lock this down in prod.
CORS_ALLOW_ORIGIN=http://localhost:8000
API_RATE_LIMIT=30/minute
